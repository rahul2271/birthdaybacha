# Dependency directories (Never commit node_modules)
node_modules/
jspm_packages/
web_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (Crashed node apps)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
.nyc_output

# next.js build output
.next/
out/

# Production build outputs
dist/
build/

# Local env files containing API keys/secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Typescript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional Stylelint cache
.stylelintcache

# OS files
.DS_Store
Thumbs.db